{
  "name": "write-like-me",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "electron:dev": "concurrently -k \"npm run dev -- --port 5173\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder --dir",
    "electron:pack": "npm run build && electron-builder",
    "test:desktop": "npm run build && node scripts/desktop-smoke.mjs",
    "test:e2e": "npm run build && node scripts/news-to-final-e2e.mjs",
    "test:services": "npm run build && cross-env ELECTRON_SERVICE_TEST=1 electron .",
    "test:electron": "npm run test:desktop"
  },
  "build": {
    "appId": "ai.fendou.writelikeme",
    "productName": "WriteLikeMe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir"
      ]
    },
    "win": {
      "target": [
        "dir"
      ]
    },
    "linux": {
      "target": [
        "dir"
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "wait-on": "^9.0.10"
  }
}
